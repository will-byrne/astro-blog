---
import { Image } from 'astro:assets';
import avatar from './assets/avatar.jpg';
---
<header>
  <a href="/" class="avatar">
    <Image src={avatar} width="112" height="112" alt="avatar">
  </a>
  <h1 class="site-title">
    <a href="/">Will's Tech Blog</a>
  </h1>
  <p class="site-subtitle">Tech, Music and Life</p>
</header>
<style>
  header {
    margin-top: 2rem;
    margin-bottom: 2rem;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    width: 100%;
    transition: all 0.3s ease-in-out;
  }

  .avatar {
    display: block;
    width: 6rem;
    height: 6rem;
    overflow: hidden;
    box-shadow: var(--avatar-border-color) 0 0 0 2px;
    transform: translateZ(0);
    border-radius: 50%;
    margin: 0 auto;
  }

  .avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s;
  }

  .avatar:hover img {
    transform: scale(1.2);
  }

  .site-title {
    font-family: inherit;
    font-weight: 900;
    font-size: 1.5rem;
    line-height: 1.2;
    letter-spacing: 0.25px;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
    transition: all 0.3s ease-in-out;
    user-select: none;
    text-align: center;
  }

  .site-title a {
    color: var(--site-title-color);
    text-decoration: none;
    transition: all 0.3s ease-in-out;
  }

  .site-title a:hover {
    color: var(--sidebar-active-color);
  }

  .site-subtitle {
    font-size: 0.9rem;
    color: var(--site-subtitle-color);
    margin-top: 0.25rem;
    margin-bottom: 0;
    word-spacing: 1px;
    user-select: none;
    text-align: center;
    font-style: italic;
  }

  @media (min-width: 850px) {
    header {
      margin-top: 2.5rem;
      padding-left: 2.5rem;
      padding-right: 1.25rem;
    }
  }
</style>