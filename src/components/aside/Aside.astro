---
import Header from './Header.astro';
import Nav from './Nav.astro';
---
<aside aria-label="Sidebar" class="sidebar">
  <Header />
  <Nav />
  <div class="sidebar-bottom">
    <a href="https://github.com/will-byrne" aria-label="github" target="_blank" rel="noopener noreferrer">
      <i class="fab fa-github"></i>
    </a>
    <a href="https://twitter.com/LunaTheAstro" aria-label="twitter" target="_blank" rel="noopener noreferrer">
      <i class="fab fa-twitter"></i>
    </a>
    <a href="javascript:location.href = 'mailto:' + ['blog+will.alex.byrne','gmail.com'].join('@')" aria-label="email">
      <i class="fas fa-envelope"></i>
    </a>
    <a href="/feed.xml" aria-label="rss">
      <i class="fas fa-rss"></i>
    </a>
  </div>
</aside>
<style>
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    height: 100%;
    overflow-y: auto;
    width: 260px;
    background: var(--sidebar-bg);
    border-right: 1px solid var(--sidebar-border-color);
    display: flex;
    flex-direction: column;
    z-index: 99;
    scrollbar-width: none;
    padding: 0;
  }

  .sidebar::-webkit-scrollbar {
    display: none;
  }

  @media screen and (max-width: 849px) {
    .sidebar {
      display: none;
      transform: translateX(-100%);
      transition: transform 0.3s ease;
    }

    .sidebar.active {
      display: flex;
      transform: translateX(0);
    }
  }

  .sidebar-bottom {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 2rem 1.5rem;
    margin-top: auto;
    border-top: 1px solid var(--sidebar-border-color);
  }

  .sidebar-bottom a {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background-color: var(--sidebar-btn-bg);
    color: var(--sidebar-btn-color);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .sidebar-bottom a:hover {
    background-color: var(--sidebar-hover-bg);
    color: var(--sidebar-active-color);
  }

  .sidebar-bottom i {
    font-size: 0.9rem;
  }
</style>