---
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = Object.values(import.meta.glob('../posts/*.md', { eager: true }));
const categories = [...new Set(allPosts.map((post: any) => post.frontmatter.category).filter(Boolean))].sort();
const pageTitle = "Categories";
---

<BaseLayout pageTitle={pageTitle}>
  <div class="categories-container">
    <p class="categories-intro">Browse posts by category</p>
    <div class="categories-grid">
      {categories.map((category) => {
        const postCount = allPosts.filter((post: any) => 
          post.frontmatter.category === category
        ).length;
        return (
          <a href={`/categories/${category}`} class="category-card">
            <span class="category-name">{category}</span>
            <span class="category-count">{postCount} {postCount === 1 ? 'post' : 'posts'}</span>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>

<style>
  .categories-container {
    max-width: 900px;
  }

  .categories-intro {
    font-size: 1.1rem;
    color: var(--text-muted-color);
    margin-bottom: 2rem;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  .category-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background-color: var(--sidebar-hover-bg);
    border: 1px solid var(--sidebar-border-color);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: all 0.3s ease;
    min-height: 120px;
  }

  .category-card:hover {
    background-color: var(--accent-color);
    border-color: var(--accent-color);
    transform: translateY(-2px);
  }

  .category-name {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--heading-color);
    margin-bottom: 0.5rem;
  }

  .category-card:hover .category-name {
    color: var(--main-bg);
  }

  .category-count {
    font-size: 0.9rem;
    color: var(--text-muted-color);
  }

  .category-card:hover .category-count {
    color: var(--main-bg);
  }
</style>
